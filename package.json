{
  "name": "hosting_for_shabat",
  "version": "1.0.0",
  "description": "A platform connecting hosts and guests (soldiers, national service volunteers, students, and families) for Shabbat hosting. The application combines rigid factual search filters with semantic vector matches, a multi-stage AI Agent for expectation alignment, and real-time in-app chat.",
  "main": "index.js",
  "scripts": {
    "dev:frontend": "npm run dev --prefix Frontend",
    
    "dev:backend": "cd Backend && python -m uvicorn app.main:app --reload",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\""
  },
  "repository": {
    "type": "git",
