# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hosting_db

# Security & JWT Configuration
JWT_SECRET=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Admin Configuration
ADMIN_EMAIL=admin@hostingforshabbat.com
ADMIN_PASSWORD=change_me_to_a_strong_password

# HuggingFace Configuration (for semantic vector search)
HF_ACCESS_TOKEN=your_huggingface_access_token_here
HF_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LangSmith Monitoring / Tracing (Optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=hosting-for-shabat

# CORS
CORS_ORIGINS=*

# SMTP / Email Verification
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com

# Telegram Bot / Phone Verification
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username_here

# Frontend URL
FRONTEND_URL=http://localhost:5173

