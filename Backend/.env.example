# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hosting_db
DATABASE_PASSWORD=your_database_password_here

# Security & JWT Configuration
JWT_SECRET=supersecretjwtkeyplaceholderforlocaldev
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Admin Configuration
ADMIN_EMAIL=admin@hostingforshabbat.com
ADMIN_PASSWORD=localadminsecretpass123

# HuggingFace Configuration (for semantic vector search)
HF_ACCESS_TOKEN=your_huggingface_access_token_here
HF_MODEL=sentence-transformers/all-MiniLM-L6-v2
